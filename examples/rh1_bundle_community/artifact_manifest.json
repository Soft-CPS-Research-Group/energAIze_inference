{
  "manifest_version": 1,
  "metadata": {
    "experiment_name": "rh1_bundle_community",
    "run_name": "rh1_house_rbc_v1_community",
    "bundle_version": "2026-04-03-v1",
    "alias_mapping_path": "aliases.json",
    "description": "R-H-01 house community-participation rule-based bundle (EV+battery+PV, real telemetry)"
  },
  "simulator": {},
  "training": {},
  "topology": {
    "num_agents": 1
  },
  "algorithm": {
    "name": "RuleBasedHouseController",
    "hyperparameters": {}
  },
  "environment": {
    "observation_names": [
      [
        "timestamp"
      ]
    ],
    "encoders": [
      [
        {
          "type": "NoNormalization",
          "params": {}
        }
      ]
    ],
    "action_bounds": [
      [
        {
          "low": [
            0.0,
            -4.8
          ],
          "high": [
            4.6,
            4.8
          ]
        }
      ]
    ],
    "action_names": [
      "EVC01",
      "B01"
    ],
    "reward_function": {
      "name": "RewardFunction",
      "params": {}
    }
  },
  "agent": {
    "format": "rule_based",
    "artifacts": [
      {
        "agent_index": 0,
        "path": "policy_agent_0.json",
        "format": "rule_based",
        "config": {
          "use_preprocessor": false,
          "strategy": "rh1_house_rbc_v1",
          "grid_import_limit_kw": 8.0,
          "control_interval_minutes": 0.25,
          "export_price_factor": 0.8,
          "ev_min_connected_kw": 1.6,
          "baseline_price_threshold_eur_kwh": 0.2,
          "battery_capacity_kwh": 4.0,
          "battery_nominal_power_kw": 4.8,
          "battery_efficiency": 0.95,
          "battery_soc_min": 0.2,
          "battery_soc_max": 0.9,
          "battery_degradation_penalty_eur_per_kwh": 0.01,
          "ev_default_capacity_kwh": 60.0,
          "price_unit_mode": "auto",
          "price_auto_mwh_threshold": 3.0,
          "soc_unit_mode": "fraction",
          "battery_soc_keys": [
            "batteries.B01.SoC",
            "electrical_storage.soc"
          ],
          "chargers": {
            "EVC01": {
              "min_kw": 1.6,
              "max_kw": 4.6
            }
          },
          "ev_action_name": "EVC01",
          "battery_action_name": "B01",
          "vehicle_capacities": {
            "EV01": 60.0
          },
          "ev_flexibility_fields": {
            "soc": "electric_vehicles.{ev_id}.SoC",
            "target_soc": "electric_vehicles.{ev_id}.flexibility.estimated_soc_at_departure",
            "departure_time": "electric_vehicles.{ev_id}.flexibility.estimated_time_at_departure"
          },
          "require_observations_envelope": true,
          "community_participation_enabled": true,
          "community_energy_in_key": "community.energy_in_total",
          "community_energy_out_key": "community.energy_out_total",
          "community_energy_deadband_kw": 0.2,
          "community_deficit_weight": 1.0,
          "community_surplus_weight": 1.0,
          "community_price_signal_key": "community.price_signal"
        }
      }
    ]
  }
}
